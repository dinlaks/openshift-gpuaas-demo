# GPU-as-a-Service on OpenShift — Environment Configuration
# Copy to env.sh and fill in your values. env.sh is gitignored.
#
# Legend:
#   [required] — must be set before running setup.sh
#   [optional] — has a safe default or is only needed for specific features
#
# Minimum required: OCP_API_URL, OCP_USERNAME, OCP_PASSWORD, GPU_TYPE, MIG_STRATEGY

# ── OpenShift Cluster ─────────────────────────────────────────────────────────
# Use your real cluster admin credentials (e.g. kubeadmin).
# Note: gpuaas-admin is a demo HTPasswd user created later by deploy-rbac.sh —
# it does not exist yet and cannot be used here for initial setup.
OCP_API_URL=https://api.your-cluster.example.com:6443  # [required]
OCP_USERNAME=kubeadmin                                  # [required]
OCP_PASSWORD=<your-admin-password>                      # [required]
OCP_CA_CERT=""  # [optional] path to CA cert file; leave empty to skip TLS verify

# ── GPU Hardware ──────────────────────────────────────────────────────────────
# Set GPU_TYPE to your exact GPU model+memory variant.
# All MIG resource names, Kueue flavor names, hardware profile requests, and
# node labels are resolved automatically — you do not need to set them manually.
#
# GPU_TYPE    | Memory | Small MIG slice         | Large MIG slice         | Default MIG profile
# ------------|--------|-------------------------|-------------------------|--------------------
# a30         | 24 GB  | nvidia.com/mig-1g.6gb   | nvidia.com/mig-2g.12gb  | mixed-a30
# a100-40gb   | 40 GB  | nvidia.com/mig-1g.5gb   | nvidia.com/mig-2g.10gb  | all-1g.5gb
# a100-80gb   | 80 GB  | nvidia.com/mig-1g.10gb  | nvidia.com/mig-2g.20gb  | all-1g.10gb
# h100-80gb   | 80 GB  | nvidia.com/mig-1g.10gb  | nvidia.com/mig-3g.40gb  | all-1g.10gb
# h100-nvl    | 94 GB  | nvidia.com/mig-1g.12gb  | nvidia.com/mig-3g.47gb  | all-1g.12gb
# h200        | 141 GB | nvidia.com/mig-1g.18gb  | nvidia.com/mig-2g.35gb  | all-1g.18gb
# custom      | any    | set manually below      | set manually below      | set manually below
#
# Tip: run  oc describe node <gpu-node> | grep nvidia.com/mig  to verify resource names.
GPU_TYPE=a30  # [required]

# ── MIG Node Configuration ────────────────────────────────────────────────────
# MIG_STRATEGY sets the default role applied to ALL GPU nodes.
# Use NODE_ROLES to override specific nodes individually.
#
# Roles available:
#   small       — uniform small MIG slices on all GPUs  (works with 1+ GPUs per node)
#   large       — uniform large MIG slices on all GPUs  (works with 1+ GPUs per node)
#   dedicated   — full GPU, no MIG partitioning         (works with 1+ GPUs per node)
#   mixed       — GPU[0]: small slices, GPU[1]: small+large MIG  (requires 2+ GPUs)
#   full-combo  — GPU[0]: small MIG slices, GPU[1]: full non-MIG (requires 2+ GPUs)
MIG_STRATEGY=<role>  # [required]
# To override for your second cluster: MIG_STRATEGY=<role> bash setup.sh --cluster b

# [optional] Per-node role overrides — nodes listed here get their specific role;
# all other GPU nodes get MIG_STRATEGY. Use exact node names from:
#   oc get nodes -l nvidia.com/gpu.present=true
# NODE_ROLES=(
#   "worker-0.cluster.example.com:small"
#   "worker-1.cluster.example.com:large"
#   "worker-2.cluster.example.com:dedicated"
#   "worker-3.cluster.example.com:mixed"
#   "worker-4.cluster.example.com:full-combo"
# )
NODE_ROLES=()

# ── Custom GPU type ───────────────────────────────────────────────────────────
# [optional] Only needed when GPU_TYPE=custom. Skip if your GPU is in the table above.
# MIG_SMALL_RESOURCE=nvidia.com/mig-Xg.Ygb
# MIG_LARGE_RESOURCE=nvidia.com/mig-Xg.Ygb
# MIG_SMALL_FLAVOR=my-gpu-mig-small
# MIG_LARGE_FLAVOR=my-gpu-mig-large
# FULL_GPU_RESOURCE=nvidia.com/gpu
# FULL_GPU_FLAVOR=my-gpu-full
# MIG_PROFILE_SMALL=all-1g.Xgb
# MIG_PROFILE_LARGE=all-Xg.Ygb
# MIG_PROFILE_MIXED=mixed-mygpu
# MIG_PROFILE_FULL_COMBO=full-combo-mygpu
# GPU_MEMORY=80gb
# GPU_ARCH=hopper

# ── Operator channels ─────────────────────────────────────────────────────────
# All channels validated for OCP 4.22 (Kubernetes 1.35), July 2026.
#
# To verify available channels on your cluster before filling these in:
#   oc get packagemanifest <package-name> -n openshift-marketplace \
#     -o jsonpath='{.status.channels[*].name}'
#
# ┌─────────────────────────────────┬────────────────────────┬──────────────────────────────────────────┐
# │ Operator                        │ Package name           │ Channel (OCP 4.22)                       │
# ├─────────────────────────────────┼────────────────────────┼──────────────────────────────────────────┤
# │ Red Hat OpenShift AI            │ rhods                  │ stable-3.4                               │
# │ Red Hat build of Kueue          │ kueue-operator          │ stable-v1.4                             │
# │ NVIDIA GPU Operator (certified) │ gpu-operator-certified │ auto-detect (v26.x — changes per release)│
# │ Node Feature Discovery          │ nfd                    │ auto-detect (OCP version-specific: 4.22) │
# │ Red Hat cert-manager            │ openshift-cert-manager-operator │ stable-v1 (fixed)            │
# │ Red Hat Service Mesh 3          │ servicemeshoperator3   │ stable (fixed)                           │
# │ Red Hat Serverless              │ serverless-operator    │ stable (fixed)                           │
# │ Web Terminal                    │ web-terminal           │ auto-detect (fast or stable)             │
# │ LVM Operator (bare-metal only)  │ lvms-operator          │ auto-detect (OCP version-specific: 4.22)│
# │ ACM (multi-cluster only)        │ advanced-cluster-management │ release-2.16 or release-2.17      │
# └─────────────────────────────────┴────────────────────────┴──────────────────────────────────────────┘
#
# "fixed" channels use stable/stable-v1 and do not need updating between OCP versions.
# "auto-detect" channels change with each OCP or operator release — leave blank to auto-detect.

RHOAI_CHANNEL=stable-3.4   # [required] update if a newer stable-3.x is released
KUEUE_CHANNEL=stable-v1.4  # [required] update if a newer stable-v1.x is released

# [optional] Leave blank to auto-detect. Override only if auto-detection fails.
GPU_OPERATOR_CHANNEL=  # or set explicitly: GPU_OPERATOR_CHANNEL=v26.3
NFD_CHANNEL=           # or set explicitly: NFD_CHANNEL=4.22
LVM_CHANNEL=           # or set explicitly: LVM_CHANNEL=stable-4.22

# [optional] Multi-cluster add-on only:
# ACM_CHANNEL=release-2.16  # or release-2.17 — both support OCP 4.22

# ── Storage ───────────────────────────────────────────────────────────────────
# [optional] Only needed if no default StorageClass exists on your cluster.
# Check first: oc get storageclass
# See optional/storage/README.md for full guidance.
#
# LVM Operator (bare-metal local disk — run lsblk to identify your disk):
# LVM_DISK_PATH=/dev/sdX   # [required if using LVM] unused block device — run lsblk to find yours
# LVM_STORAGE_CLASS=lvms-vg1  # [optional] defaults to lvms-vg1
#
# MinIO (ACM Observability only — multi-cluster add-on):
# MINIO_ACCESS_KEY=minio        # [required if using MinIO]
# MINIO_SECRET_KEY=minio123     # [required if using MinIO] change for shared environments
# MINIO_ENDPOINT=http://minio.minio.svc.cluster.local:9000  # [required if using MinIO] default — namespace and service name are fixed

# ── Demo User Passwords ───────────────────────────────────────────────────────
# [required] Passwords for HTPasswd demo users created by deploy-rbac.sh.
# These are tenant users for the use case demos — not cluster admins.
# Change to your preferred values before running deploy-rbac.sh.
DEMO_PASS_ADMIN=GPUaaS-Admin-2026!
DEMO_PASS_ALICE=Alice-Infer-2026!
DEMO_PASS_BOB=Bob-DataSci-2026!
DEMO_PASS_CHARLIE=Charlie-Rsrch-2026!
DEMO_PASS_DIANA=Diana-Ftune-2026!
DEMO_PASS_EVE=Eve-Anlytcs-2026!

# ── Multi-cluster Add-on (UC7 only — skip for single-cluster setup) ───────────
# [optional] Only needed for UC7 (global GPU pool across two clusters).
# Cluster A = hub (ACM + MultiKueue control plane)
# Cluster B = spoke (jobs dispatched here by MultiKueue)
#
# CLUSTER_A_API_URL=https://api.cluster-a.example.com:6443  # [required for UC7]
# CLUSTER_A_USERNAME=kubeadmin                              # [required for UC7]
# CLUSTER_A_PASSWORD=<password>                             # [required for UC7]
# CLUSTER_A_KUBECONFIG=<path-to-kubeconfig-a>              # [optional] alternative to username/password

# CLUSTER_B_API_URL=https://api.cluster-b.example.com:6443  # [required for UC7]
# CLUSTER_B_USERNAME=kubeadmin                              # [required for UC7]
# CLUSTER_B_PASSWORD=<password>                             # [required for UC7]
# CLUSTER_B_KUBECONFIG=<path-to-kubeconfig-b>              # [optional] alternative to username/password
# Note: CLUSTER_B_NAME is auto-detected from the OCP infrastructure name (no manual config needed)
# Note: MINIO_ENDPOINT for UC7 ACM Observability is set in the Storage section above.
