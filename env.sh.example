# GPU-as-a-Service on OpenShift — Environment Configuration
# Copy to env.sh and fill in your values. env.sh is gitignored.
#
# Minimum required: OCP_API_URL, OCP_USERNAME, OCP_PASSWORD
# GPU variables drive the node-labels and MIG scripts.
# Multi-cluster variables are only needed for the multi-cluster/ add-on (UC7).

# ── OpenShift Cluster ─────────────────────────────────────────────────────────
OCP_API_URL=https://api.your-cluster.example.com:6443
OCP_USERNAME=gpuaas-admin
OCP_PASSWORD=<your-admin-password>
OCP_CA_CERT=""   # path to CA cert file; leave empty to skip TLS verify

# ── GPU Hardware ──────────────────────────────────────────────────────────────
# Set GPU_TYPE to your exact GPU model+memory variant.
# All MIG resource names, Kueue flavor names, hardware profile requests, and
# node labels are resolved automatically — you do not need to set them manually.
#
# GPU_TYPE    | Memory | Small MIG slice         | Large MIG slice         | Default MIG profile
# ------------|--------|-------------------------|-------------------------|--------------------
# a30         | 24 GB  | nvidia.com/mig-1g.6gb   | nvidia.com/mig-2g.12gb  | mixed-a30
# a100-40gb   | 40 GB  | nvidia.com/mig-1g.5gb   | nvidia.com/mig-2g.10gb  | all-1g.5gb
# a100-80gb   | 80 GB  | nvidia.com/mig-1g.10gb  | nvidia.com/mig-2g.20gb  | all-1g.10gb
# h100-80gb   | 80 GB  | nvidia.com/mig-1g.10gb  | nvidia.com/mig-3g.40gb  | all-1g.10gb
# h100-nvl    | 94 GB  | nvidia.com/mig-1g.12gb  | nvidia.com/mig-3g.47gb  | all-1g.12gb
# h200        | 141 GB | nvidia.com/mig-1g.18gb  | nvidia.com/mig-2g.35gb  | all-1g.18gb
# custom      | any    | set manually below      | set manually below      | set manually below
#
# Tip: run  oc describe node <gpu-node> | grep nvidia.com/mig  to verify resource names.
GPU_TYPE=a30

# ── MIG Node Configuration ────────────────────────────────────────────────────
# MIG_STRATEGY sets the default role applied to ALL GPU nodes.
# Use NODE_ROLES to override specific nodes individually.
#
# Roles available:
#   small       — uniform small MIG slices on all GPUs  (works with 1+ GPUs per node)
#   large       — uniform large MIG slices on all GPUs  (works with 1+ GPUs per node)
#   dedicated   — full GPU, no MIG partitioning         (works with 1+ GPUs per node)
#   mixed       — GPU[0]: small slices, GPU[1]: small+large MIG  (requires 2+ GPUs)
#   full-combo  — GPU[0]: small MIG slices, GPU[1]: full non-MIG (requires 2+ GPUs)
MIG_STRATEGY=small

# NODE_ROLES — per-node role overrides (optional).
# Nodes listed here get their specific role; all other GPU nodes get MIG_STRATEGY.
#
# IMPORTANT: Use the exact node name from:  oc get nodes -l nvidia.com/gpu.present=true
# Node names are FQDNs on bare-metal OCP, e.g. worker-0.cluster.example.com
# If a name doesn't match, the script will warn and fall back to MIG_STRATEGY.
#
# NODE_ROLES=(
#   "worker-0.cluster.example.com:small"
#   "worker-1.cluster.example.com:large"
#   "worker-2.cluster.example.com:dedicated"
#   "worker-3.cluster.example.com:mixed"
#   "worker-4.cluster.example.com:full-combo"
# )
NODE_ROLES=()

# ── Custom GPU type (only needed when GPU_TYPE=custom) ────────────────────────
# Set all of these when your GPU is not in the table above.
# MIG_SMALL_RESOURCE=nvidia.com/mig-Xg.Ygb
# MIG_LARGE_RESOURCE=nvidia.com/mig-Xg.Ygb
# MIG_SMALL_FLAVOR=my-gpu-mig-small
# MIG_LARGE_FLAVOR=my-gpu-mig-large
# FULL_GPU_RESOURCE=nvidia.com/gpu
# FULL_GPU_FLAVOR=my-gpu-full
# MIG_PROFILE_SMALL=all-1g.Xgb
# MIG_PROFILE_LARGE=all-Xg.Ygb
# MIG_PROFILE_MIXED=mixed-mygpu
# MIG_PROFILE_FULL_COMBO=full-combo-mygpu
# GPU_MEMORY=80gb
# GPU_ARCH=hopper

# ── Operator channels ─────────────────────────────────────────────────────────
RHOAI_CHANNEL=stable-3.3    # RHOAI channel; check oc get packagemanifest rhods
KUEUE_CHANNEL=stable-v1.3   # Kueue channel; check oc get packagemanifest openshift-kueue-operator

# ── Storage (optional — only needed if no default StorageClass exists) ─────────
# Skip this section if: oc get storageclass  shows a (default) StorageClass.
# Required for: bare-metal OCP with local disks (LVM), or ACM Observability (MinIO).
# See optional/storage/README.md for full guidance.
#
# LVM Operator (bare-metal local disk storage):
# LVM_DISK_PATH=/dev/sdb        # unused block device — run: lsblk to find yours
# LVM_STORAGE_CLASS=lvms-vg1    # StorageClass name created by LVM Operator
# LVM_CHANNEL=stable-4.21       # match your OCP version: stable-4.17, stable-4.18, etc.
#
# MinIO (ACM Observability only — multi-cluster add-on):
# MINIO_ACCESS_KEY=minio
# MINIO_SECRET_KEY=minio123     # change for any shared environment
# MINIO_ENDPOINT=http://minio.minio.svc.cluster.local:9000

# ── Demo User Passwords ───────────────────────────────────────────────────────
# Change these to your preferred passwords before running deploy-rbac.sh
DEMO_PASS_ADMIN=GPUaaS-Admin-2026!
DEMO_PASS_ALICE=Alice-Infer-2026!
DEMO_PASS_BOB=Bob-DataSci-2026!
DEMO_PASS_CHARLIE=Charlie-Rsrch-2026!
DEMO_PASS_DIANA=Diana-Ftune-2026!
DEMO_PASS_EVE=Eve-Anlytcs-2026!

# ── Multi-cluster Add-on (multi-cluster/ only — skip for single-cluster setup) ─
